{
  "bundle": {
    "windows": {
      "signCommand": {
        "cmd": "powershell.exe",
        "args": [
          "-NoProfile",
          "-NonInteractive",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "../scripts/windows-artifact-sign.ps1",
          "-FilePath",
          "%1"
        ]
      }
    }
  }
}
